/target
/sif
**/*.rs.bk
.DS_Store
bench/work/
*.sif
*.bam.bai

# Bench results: ignore the large raw/joined dirs but keep the small
# committed artifacts (plots, SUMMARY, per_feature_corr, notebook).
bench/results/*/raw/
bench/results/*/joined/
bench/results/*/excluded/
bench/results/*/logs/
bench/results/*/parse.log
bench/results/*/notebook.log
bench/results/*/notebook_manual.log
bench/results/*/agg_bg.log
bench/results/*/parse_all.log

# Local Claude Code settings
.claude/

# Test fixture BAMs (regenerate via bench/capture_fixture.sh if needed)
tests/data/fixtures/*/region.bam
tests/data/fixtures/*/region.bam.bai
tests/data/fixtures/*/got.txt
tests/data/fixtures/*/brc.stderr
bench/results/*/benchmark.ipynb

# Sample-picking glue: contains cohort names + sample IDs, do NOT commit
bench/run_one_sample.sh
bench/submit_array.sh
bench/sample_picker.py
bench/samples.tsv
bench/results/.latest_runid
bench/excluded_samples.txt
bench/results/*/per_sample_metrics.tsv
bench/results/*/SUMMARY.md
# Smoke / 200-sample preliminary runs aren't shipped with the README
bench/results/200samples_l2l3/
bench/results/200samples_*/

# Local Python / Slurm scratch
bench/__pycache__/
bench/logs/
bench/smoke_l2l3/
slurm/
